# Django — copy to .env and set real values. Never commit .env.
# Required
DJANGO_SECRET_KEY=your-secret-key-at-least-50-chars
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: leave unset for SQLite, or set for PostgreSQL
# DB_ENGINE=postgresql
# DB_NAME=appdb
# DB_USER=app
# DB_PASSWORD=app
# DB_HOST=db
# DB_PORT=5432
# Or: DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Frontend URL (for verification/reset links)
FRONTEND_URL=http://localhost:3000

# Email: console | gmail | ses
EMAIL_MODE=console
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com
# AWS_ACCESS_KEY_ID= (for SES)
# AWS_SECRET_ACCESS_KEY=
# AWS_SES_REGION=us-east-1

# Seed demo (optional; override in production)
# SEED_ADMIN_PASSWORD=admin123
# SEED_DEMO_PASSWORD=demo123

# Cloudflare R2 (optional — file uploads)
# USE_CLOUDFLARE_R2=False
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
# R2_CUSTOM_DOMAIN=

# Tap Payments (optional — see TAP_SETUP.md)
# TAP_SECRET_KEY=
# FRONTEND_APP_URL=http://localhost:3000

# Cloudinary (optional — images)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
